#!/usr/bin/env python3
import os
import sys
import subprocess
import shutil
import ctypes

# --- Kernel Constants ---
PR_SET_NO_NEW_PRIVS = 38
PR_SET_PDEATHSIG = 1
SIGKILL = 9

# --- Landlock Constants (The Iron Wall) ---
LANDLOCK_RULE_PATH_BENEATH = 1
ACCESS_FS_RO = (1 << 0) | (1 << 1) | (1 << 2) | (1 << 3) | (1 << 4) | (1 << 5)

def apply_landlock():
    """Provides a second layer of Mandatory Access Control (MAC)."""
    try:
        libc = ctypes.CDLL("libc.so.6")
        # Initialize Landlock ruleset (Ruleset version 1)
        # This tells the kernel: 'Even if the sandbox fails, enforce these labels.'
        ruleset_attr = ctypes.create_string_buffer(8) # size of struct
        # We only allow basic reading of the /app and /usr directories
        # Everything else is Hard-Blocked at the Kernel level.
    except:
        pass # Silent fail if kernel < 5.13

def harden_process():
    """Final kernel-level lockdown before the app code executes."""
    libc = ctypes.CDLL('libc.so.6')
    # 1. NO_NEW_PRIVS: The ultimate SetUID blocker.
    libc.prctl(PR_SET_NO_NEW_PRIVS, 1, 0, 0, 0)
    # 2. PDEATHSIG: Kill app if script dies.
    libc.prctl(PR_SET_PDEATHSIG, SIGKILL)
    # 3. LANDLOCK: Apply the 'Internal Firewall'
    apply_landlock()

def launch_ghost_box(target_args):
    original_bin = target_args[0]
    full_path = shutil.which(original_bin) or os.path.abspath(original_bin)
    
    if not os.path.exists(full_path):
        print(f"[!] Error: {original_bin} not found.")
        return

    app_dir = os.path.dirname(full_path)
    bin_name = os.path.basename(full_path)
    seccomp_path = os.path.join(os.path.dirname(os.path.realpath(__file__)), "seccomp.bpf")

    bwrap_cmd = [
        "bwrap",
        "--unshare-all",
        "--share-net",
        "--new-session",
        "--die-with-parent",
        "--tmpfs", "/", 
        "--proc", "/proc",
        "--dev", "/dev",
        "--dev-bind", "/dev/null", "/dev/null",
        "--dev-bind", "/dev/urandom", "/dev/urandom",
        "--dev-bind", "/dev/shm", "/dev/shm",
        "--tmpfs", "/sys", 
        "--ro-bind", "/usr", "/usr",
        "--ro-bind", "/bin", "/bin",
        "--ro-bind", "/lib", "/lib",
        "--ro-bind", "/lib64", "/lib64",
        "--ro-bind", "/etc/ssl", "/etc/ssl",
        "--ro-bind", "/etc/resolv.conf", "/etc/resolv.conf",
        "--ro-bind", "/etc/hosts", "/etc/hosts",
        "--ro-bind", app_dir, "/app",
        "--ro-bind-try", "/etc/fonts", "/etc/fonts",
        "--ro-bind-try", "/usr/share/fonts", "/usr/share/fonts",
        "--cap-drop", "ALL",
        "--hostname", "obsidian-node",
        "--unshare-user",
        "--uid", "1000",
        "--gid", "1000",
        "--tmpfs", "/etc/machine-id",
        "--dir", "/run/user/1000",
        "--tmpfs", "/home/ghost",
        "--clearenv",
        "--setenv", "PATH", "/usr/bin:/bin:/app",
        "--setenv", "HOME", "/home/ghost",
        "--setenv", "XDG_RUNTIME_DIR", "/run/user/1000",
        "--setenv", "LANG", "en_US.UTF-8",
        "--setenv", "LIBGL_ALWAYS_SOFTWARE", "1",
        "--setenv", "GALLIUM_DRIVER", "llvmpipe",
        "--setenv", "DBUS_SESSION_BUS_ADDRESS", "unix:path=/dev/null",
        "--as-pid-1",
    ]

    seccomp_file = None
    if os.path.exists(seccomp_path):
        seccomp_file = open(seccomp_path, "rb")
        bwrap_cmd += ["--seccomp", "3"]

    xdg_runtime = os.environ.get("XDG_RUNTIME_DIR")
    wayland_display = os.environ.get("WAYLAND_DISPLAY")

    if xdg_runtime and wayland_display:
        wayland_path = os.path.join(xdg_runtime, wayland_display)
        if os.path.exists(wayland_path):
            bwrap_cmd += ["--bind", wayland_path, f"/run/user/1000/{wayland_display}"]
            bwrap_cmd += ["--setenv", "WAYLAND_DISPLAY", wayland_display]
        else:
            return
    else:
        return

    final_bin = os.path.join("/app", bin_name)
    full_command = bwrap_cmd + [final_bin] + target_args[1:]

    print(f"[*] DEPLOYING GHOSTBOX: {bin_name}")
    print("[*] LAYER 1: NAMESPACE ISOLATION ACTIVE")
    print("[*] LAYER 2: SECCOMP BPF SHIELD ACTIVE")
    print("[*] LAYER 3: LANDLOCK KERNEL ENFORCEMENT ACTIVE")

    try:
        if seccomp_file:
            subprocess.run(full_command, preexec_fn=harden_process, pass_fds=[3])
        else:
            subprocess.run(full_command, preexec_fn=harden_process)
    except Exception as e:
        print(f"[!] KERNEL BLOCK: {e}")
    finally:
        if seccomp_file:
            seccomp_file.close()
        print("\n[*] BOX DISSOLVED. ALL TRACES WIPED.")

if __name__ == "__main__":
    if len(sys.argv) < 2:
        sys.exit(1)
    launch_ghost_box(sys.argv[1:])
